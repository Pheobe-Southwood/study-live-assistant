<Window x:Class="StudyLiveAssistant.App.Views.StudyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="学习模式" Width="590" Height="290" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" Topmost="True" ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen" Closed="Window_Closed">
    <Border Background="#FAFFFFFF" BorderBrush="#D7E2E2" BorderThickness="1" CornerRadius="18" Padding="22" MouseLeftButtonDown="DragArea_MouseLeftButtonDown">
        <Border.Effect><DropShadowEffect Color="#33000000" BlurRadius="18" ShadowDepth="3"/></Border.Effect>
        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="{Binding Title}" FontSize="21" FontWeight="SemiBold"/><TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/></StackPanel>
                <Button Grid.Column="1" Content="配置" Command="{Binding ReturnCommand}" ToolTip="返回配置窗口" Padding="10,5"/>
            </Grid>
            <Grid Grid.Row="1" Margin="0,16,0,5"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ProgressText}" FontSize="14"/><TextBlock Grid.Column="1" Text="{Binding Elapsed}" FontFamily="Consolas" FontSize="17" FontWeight="SemiBold"/>
            </Grid>
            <ProgressBar Grid.Row="2" Height="9" Minimum="0" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}" Foreground="{StaticResource Primary}"/>
            <Grid Grid.Row="3" Margin="0,16,0,8"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="‹" Command="{Binding PreviousCommand}" ToolTip="上一任务" FontSize="24"/>
                <Button Grid.Column="1" Content="−" Command="{Binding DecrementCommand}" ToolTip="进度减一" FontSize="22"/>
                <Button Grid.Column="2" Content="{Binding PlayIcon}" Command="{Binding PlayPauseCommand}" ToolTip="播放 / 暂停" FontSize="21" Style="{StaticResource PrimaryButton}"/>
                <Button Grid.Column="3" Content="+" Command="{Binding IncrementCommand}" ToolTip="进度加一" FontSize="22"/>
                <Button Grid.Column="4" Content="›" Command="{Binding NextCommand}" ToolTip="下一任务" FontSize="24"/>
                <Button Grid.Column="5" Content="✓" Command="{Binding CompleteCommand}" ToolTip="标记完成" FontSize="20"/>
            </Grid>
            <Grid Grid.Row="4"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding NextTask}" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource Primary}" Margin="12,0,0,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
