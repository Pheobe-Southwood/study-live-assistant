<Window x:Class="StudyLiveAssistant.App.Views.LiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:StudyLiveAssistant.App.Views"
        Title="自习直播主页面" WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="True"
        Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}"
        Left="{Binding Appearance.WindowLeft}" Top="{Binding Appearance.WindowTop}"
        Loaded="Window_Loaded" Closed="Window_Closed" LocationChanged="Window_LocationChanged" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <views:StringToBrushConverter x:Key="StringToBrush"/>
        <views:ThemeCornerRadiusConverter x:Key="ThemeCorner"/>
        <views:ThemeCardBrushConverter x:Key="ThemeCardBrush"/>
        <views:ProgressCornerRadiusConverter x:Key="ProgressCorner"/>
        <views:ProgressMaskConverter x:Key="ProgressMask"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>
    <Grid Background="{Binding InfoBackgroundBrush}" TextElement.FontFamily="{Binding Appearance.FontFamily}" TextElement.Foreground="{Binding FontBrush}">
        <Grid.RowDefinitions><RowDefinition Height="{Binding TopHeight}"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid.ColumnDefinitions><ColumnDefinition Width="{Binding LeftWidth}"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{Binding InfoBackgroundBrush}" ClipToBounds="True" BorderBrush="#22000000" BorderThickness="0,0,0,1">
            <Grid x:Name="TopInfoViewport" ClipToBounds="True">
                <TextBlock x:Name="TopInfoText" Text="{Binding TopInfoText}" FontSize="{Binding Appearance.TopFontSize}"
                           Foreground="{Binding FontBrush}" FontWeight="SemiBold" VerticalAlignment="Center"
                           HorizontalAlignment="Center" TextWrapping="NoWrap"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="{Binding InfoBackgroundBrush}" Padding="18" BorderBrush="#22000000" BorderThickness="0,0,1,0">
            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel Margin="4,2,4,16">
                    <TextBlock Text="今日任务" FontSize="{Binding Appearance.TitleFontSize}" FontWeight="Bold"/>
                    <TextBlock Text="按计划，一项一项来" FontSize="{Binding Appearance.BodyFontSize}" Opacity="0.65"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding TaskCards}"><ItemsControl.ItemTemplate><DataTemplate>
                        <Border x:Name="TaskCard" Margin="3,5" Padding="14"
                                BorderBrush="{Binding AccentColor, Converter={StaticResource StringToBrush}}" BorderThickness="2,0,0,0"
                                CornerRadius="{Binding DataContext.Theme, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ThemeCorner}}">
                            <StackPanel>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Title}" FontSize="{Binding DataContext.Appearance.TitleFontSize, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TimeText}" FontSize="{Binding DataContext.Appearance.BodyFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Opacity="0.7" Margin="10,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ElapsedText}" FontSize="{Binding DataContext.Appearance.BodyFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Opacity="0.75"/>
                                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontSize="{Binding DataContext.Appearance.BodyFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Opacity="0.75"/>
                                </Grid>
                                <ProgressBar Height="10" Margin="0,10,0,2" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}"
                                             Foreground="{Binding AccentColor, Converter={StaticResource StringToBrush}}"
                                             Visibility="{Binding DataContext.ShowProgressBar, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                                    <ProgressBar.Template><ControlTemplate TargetType="ProgressBar">
                                        <Border Background="#26000000" CornerRadius="{Binding DataContext.Appearance.ProgressStyle, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ProgressCorner}}" ClipToBounds="True">
                                            <Grid x:Name="PART_Track"><Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}"
                                                CornerRadius="{Binding DataContext.Appearance.ProgressStyle, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ProgressCorner}}"
                                                OpacityMask="{Binding DataContext.Appearance.ProgressStyle, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ProgressMask}}"/></Grid>
                                        </Border>
                                    </ControlTemplate></ProgressBar.Template>
                                </ProgressBar>
                                <TextBlock Text="{Binding ProgressText}" FontSize="{Binding DataContext.Appearance.BodyFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Opacity="0.72" HorizontalAlignment="Right"/>
                            </StackPanel>
                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{Binding DataContext.Theme, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ThemeCardBrush}}"/><Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrent}" Value="True"><Setter Property="Background" Value="#FFFFFFFF"/><Setter Property="BorderThickness" Value="5,0,0,0"/></DataTrigger>
                                <DataTrigger Binding="{Binding IsNext}" Value="True"><Setter Property="Background" Value="#DDF7FAF9"/></DataTrigger>
                            </Style.Triggers></Style></Border.Style>
                        </Border>
                    </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="{Binding ChromaBrush}"/>
    </Grid>
</Window>
