<Application x:Class="StudyLiveAssistant.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#F5F7F8"/>
        <SolidColorBrush x:Key="Surface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Primary" Color="#507C78"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#416965"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#243238"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6C7A80"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DDE4E6"/>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="TextElement.FontSize" Value="14"/>
            <Setter Property="Background" Value="{StaticResource AppBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Primary}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinWidth" Value="110"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </Application.Resources>
</Application>
